@model GloboTicket.Frontend.Models.Api.Event
<tr>
    <td>
        <img class="artistPic" src="@Model!.ImageUrl" alt="Artist pic" />
    </td>
    <td>
        @Model.Date.ToShortDateString()
    </td>
    <td>
        @Model.Name
        @if(Model.IsOnSpecialOffer) {
            <span class="specialOffer">SPECIAL&nbsp;OFFER</span>
        }
        @if (Model.TicketsAvailable == 0)
        {
            <span class="soldOut">SOLD&nbsp;OUT</span>
        }
        else if (Model.TicketsAvailable <= 10)
        {
            <span class="lowStock">ONLY&nbsp;@Model.TicketsAvailable&nbsp;LEFT</span>
        }
    </td>
    <td>
        @Model.Artist
    </td>
    <td class="bold big">
        $@Model.Price
    </td>
    <td>
        <a class="btn btn-primary" asp-action="Detail" asp-route-eventId="@Model.EventId">PURCHASE DETAILS</a>
    </td>
</tr>
